rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function roleFromUidDoc() {
      let uid = isSignedIn() ? request.auth.uid : '__signed_out__';
      let roleDoc = get(/databases/$(database)/documents/user_roles/$(uid));
      return isSignedIn() && roleDoc.exists() && roleDoc.data.role is string
        ? roleDoc.data.role
        : '';
    }

    function effectiveRole() {
      let docRole = roleFromUidDoc();
      return docRole != ''
        ? docRole
        : (request.auth.token.role is string ? request.auth.token.role : '');
    }

    function hasValidRole() {
      return isSignedIn() && effectiveRole() in ['Admin', 'Staff', 'Reseller'];
    }

    function isAdminOrStaff() {
      return hasValidRole() && effectiveRole() in ['Admin', 'Staff'];
    }

    function canReadOwnRoleDoc(roleId) {
      return isSignedIn()
        && (
          roleId == request.auth.uid
          || (
            request.auth.token.email is string
            && roleId == request.auth.token.email
          )
        );
    }

    match /orders/{orderId} {
      allow read, create, update, delete: if hasValidRole();
    }

    match /app_data/{docId} {
      allow read, create, update, delete: if hasValidRole();
    }

    match /catalog_orders/{code} {
      allow read: if hasValidRole();
      // Public catalog can create order codes without sign-in.
      // Admin/staff still require sign-in for read/update/delete.
      allow create: if request.resource != null
        && request.resource.data.code is string
        && request.resource.data.code == code
        && request.resource.data.code.matches('^JR-[A-Z0-9]{6}$')
        && request.resource.data.ts is number
        && request.resource.data.total is number;
      allow update, delete: if hasValidRole();
    }

    match /media/{mediaId} {
      allow read, create, update, delete: if hasValidRole();
    }

    match /audit_logs/{logId} {
      allow read: if isAdminOrStaff();
      allow create: if hasValidRole();
      allow update, delete: if isAdminOrStaff();
    }

    match /user_roles/{roleId} {
      allow read: if isAdminOrStaff() || canReadOwnRoleDoc(roleId);
      allow create, update, delete: if isAdminOrStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
